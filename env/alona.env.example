# Copy to /etc/alona/alona.env on the Pi and restrict permissions: chmod 600
# Load before starting the app: set -a && source /etc/alona/alona.env && set +a

# Phoenix / Ecto (prod)
export MIX_ENV=prod
export PHX_SERVER=true
export PORT=4000
export PHX_HOST=alona.local

# Generated on the Pi: mix phx.gen.secret
export SECRET_KEY_BASE=CHANGE_ME

# Created by scripts/setup-pi.sh (defaults shown)
export DATABASE_URL=ecto://alona:alona@localhost/alona_os_core_prod
export POOL_SIZE=10

# MQTT — alona_ingest subscriber (living room ESP32 MVP)
export ALONA_MQTT_HOST=localhost
export ALONA_MQTT_PORT=1883
export ALONA_MQTT_TOPICS=alona/esp32/living-room/telemetry
# export ALONA_MQTT_ENABLED=false   # disable broker connection (UI-only dev)
# export ALONA_MQTT_USERNAME=
# export ALONA_MQTT_PASSWORD=
